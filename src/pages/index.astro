---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profileImage from '../../public/profile.jpg';
---

<Layout title="Javi Rubio">
  <div class="content-container">
    <section class="hero">
      <div class="hero-header">
        <div>
          <h1>Javi Rubio</h1>
          <p class="typed-roles">
            <span id="typed-role"></span>
          </p>
          <p class="subtitle">Helping teams build better products, knowledge systems, and sustainable work cultures.</p>
        </div>
        <Image src={profileImage} alt="Javi Rubio" class="profile-photo" width={200} height={200} />
      </div>

      <p class="intro">
        20 years working at the intersection of product, engineering, and knowledge management. I've been part of startups from day one, served as CTO, led complex technical products, and built developer experience systems.
      </p>

      <p class="intro">
        I speak at tech conferences and corporate events, organize communities, and work with organizations on AI strategy, collaboration practices, and sustainable work cultures.
      </p>

      <p class="intro">
        Known for championing <a href="https://nomeetings.work" target="_blank" rel="noopener noreferrer"><strong>#NoMeetings</strong></a>, helping distributed teams rethink collaboration beyond default rituals.
      </p>
    </section>
  </div>
</Layout>

<script>
  import Typed from 'typed.js';

  const roles = [
    'Tech Writer',
    'Developer Relations',
    'Chief Technical Officer',
    'Associate Professor',
    'Android Dev',
    'Technical Coach',
    'Technical Product Manager',
    'Product Engineer'
  ].sort(() => Math.random() - 0.5);

  new Typed('#typed-role', {
    strings: roles,
    typeSpeed: 60,
    backSpeed: 30,
    backDelay: 1600,
    loop: true,
    showCursor: true,
    cursorChar: '|'
  });
</script>

<style>
  .hero {
    text-align: left;
  }

  .hero-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .profile-photo {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    animation: fadeIn 0.8s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .typed-roles {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--color-magenta);
    min-height: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--color-black);
  }

  /* Typed.js cursor styling */
  :global(.typed-cursor) {
    color: var(--color-magenta);
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .hero-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin-bottom: 1rem;
    }

    .profile-photo {
      width: 150px;
      height: 150px;
      order: -1;
    }

    .typed-roles {
      font-size: 1.1rem;
    }

    .subtitle {
      font-size: 1.1rem;
    }
  }
</style>
