---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Javi Rubio">
  <div class="home-container">
    <section class="hero">
      <div class="hero-header">
        <div>
          <h1>Javi Rubio</h1>
          <p class="tagline">Helping teams build better products, knowledge systems, and sustainable work cultures.</p>
        </div>
        <img src="/profile.jpg" alt="Javi Rubio" class="profile-photo" />
      </div>

      <p class="bio">
        20 years working at the intersection of product, engineering, and knowledge management. I've been part of startups from day one, served as CTO, led complex technical products, and built developer experience systems.
      </p>

      <p class="bio">
        I speak at tech conferences and corporate events, organize communities, and work with organizations on AI strategy, collaboration practices, and sustainable work cultures.
      </p>

      <p class="bio">
        Known for championing <strong>#NoMeetings</strong>, helping distributed teams rethink collaboration beyond default rituals.
      </p>

      <p class="bio">
        I work with organizations on speaking engagements, workshops, and advisory projects. Let's talk.
      </p>

      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">Schedule a call</a>
        <a href="/speaking" class="btn-secondary">View speaking</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .home-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero {
    text-align: left;
  }

  .hero-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .profile-photo {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--color-black);
  }

  .bio {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .btn-primary {
    background-color: var(--color-magenta);
    color: var(--color-white);
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.9;
    text-decoration: none;
  }

  .btn-secondary {
    color: var(--color-turquoise);
    padding: 0.75rem 1.5rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .hero-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .profile-photo {
      width: 150px;
      height: 150px;
      order: -1;
    }

    h1 {
      font-size: 2rem;
    }

    .tagline {
      font-size: 1.1rem;
    }

    .bio {
      font-size: 1rem;
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .btn-primary,
    .btn-secondary {
      text-align: center;
      width: 100%;
    }
  }
</style>
