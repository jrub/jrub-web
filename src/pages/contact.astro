---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Javi Rubio">
  <div class="content-container">
    <h1>Let's talk</h1>

    <p class="intro">
      Available for speaking, workshops, and advisory work.
    </p>

    <p class="intro">
      Also open to informal conversations and collaborations on AI strategy, product thinking, and work culture. Ping me at <a href="mailto:jrubr@duck.com">jrubr@duck.com</a> or just schedule a call:
    </p>

    <div class="timetime-embed">
      <iframe
        src="https://app.timetime.in/b/fc270c46-17dd-4d47-ad67-531b7cd372fa?hideInfo=true"
        width="100%"
        height="100%"
        style="border: none; min-height: 600px"
        title="Schedule a call with Javi Rubio"
      ></iframe>
    </div>
  </div>
</Layout>

<style>
  .timetime-embed {
    width: 100%;
    min-height: 600px;
  }

  @media (max-width: 768px) {
    .timetime-embed {
      min-height: 420px;
    }

    .timetime-embed iframe {
      min-height: 420px !important;
    }
  }
</style>
