---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Javi Rubio">
  <div class="contact-container">
    <h1>Let's talk</h1>

    <p class="intro">
      Open to conversations and collaborations on AI strategy, product thinking, or work culture.
      Available for speaking, workshops, and advisory work.
    </p>

    <p class="intro">
      Send me an email at <a href="mailto:jrubr@duck.com">jrubr@duck.com</a> or schedule a call below:
    </p>

    <div class="timetime-embed">
      <iframe
        src="https://app.timetime.in/b/fc270c46-17dd-4d47-ad67-531b7cd372fa?hideInfo=true"
        width="100%"
        height="100%"
        style="border: none; min-height: 600px"
        title="Schedule a call with Javi Rubio"
      ></iframe>
    </div>
  </div>
</Layout>

<style>
  .contact-container {
    max-width: 800px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .intro {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .intro:last-of-type {
    margin-bottom: 2.5rem;
  }

  .intro a {
    font-weight: 500;
  }

  .timetime-embed {
    width: 100%;
    min-height: 600px;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .intro {
      font-size: 1rem;
    }
  }
</style>
