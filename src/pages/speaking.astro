---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import scbcn25 from '../assets/photos/SCBCN25 - Documenting APIs.jpeg';
import scbcn24 from '../assets/photos/SCBCN24 - AI in Support teams.jpeg';
import scbcn23 from '../assets/photos/SCBCN23 - We\'re capitalists.jpeg';
import scbcn22 from '../assets/photos/SCBCN22 - NoMeetings Open Space.jpeg';
import cas22Graphic from '../assets/photos/CAS22 - NoMeetings - w graphic recorder.jpeg';
import cas22 from '../assets/photos/CAS22 - NoMeetings.jpeg';
import aos23 from '../assets/photos/AOS23 - Event organizers.jpeg';
---

<Layout title="Speaking - Javi Rubio">
  <div class="content-container">
    <div class="photo-carousel" aria-hidden="true">
      <div class="photo-slide landscape">
        <Picture src={scbcn25} alt="Speaking at conference" widths={[360, 720]} sizes="360px" formats={['avif', 'webp']} />
        <span class="photo-caption">SCBCN25 - Documenting APIs</span>
      </div>
      <div class="photo-slide portrait">
        <Picture src={scbcn24} alt="Speaking at conference" widths={[280, 560]} sizes="280px" formats={['avif', 'webp']} />
        <span class="photo-caption">SCBCN24 - AI in Support teams</span>
      </div>
      <div class="photo-slide landscape">
        <Picture src={scbcn23} alt="Speaking at conference" widths={[360, 720]} sizes="360px" formats={['avif', 'webp']} />
        <span class="photo-caption">SCBCN23 - We're capitalists</span>
      </div>
      <div class="photo-slide portrait">
        <Picture src={scbcn22} alt="Speaking at conference" widths={[280, 560]} sizes="280px" formats={['avif', 'webp']} />
        <span class="photo-caption">SCBCN22 - NoMeetings Open Space</span>
      </div>
      <div class="photo-slide portrait">
        <Picture src={cas22Graphic} alt="Speaking at conference" widths={[280, 560]} sizes="280px" formats={['avif', 'webp']} />
        <span class="photo-caption">CAS22 - NoMeetings & bgcampa</span>
      </div>
      <div class="photo-slide landscape">
        <Picture src={cas22} alt="Speaking at conference" widths={[360, 720]} sizes="360px" formats={['avif', 'webp']} />
        <span class="photo-caption">CAS22 - NoMeetings</span>
      </div>
      <div class="photo-slide portrait">
        <Picture src={aos23} alt="Speaking at conference" widths={[280, 560]} sizes="280px" formats={['avif', 'webp']} />
        <span class="photo-caption">AOS23 - Event organizers</span>
      </div>
    </div>

    <h1>Speaking</h1>
    <p class="intro">I regularly speak at corporate events and tech conferences:</p>

    <ul class="talks-list-inline">
          <li class="talk">
            <a href="https://www.youtube.com/watch?v=IHIsuIlSiio" target="_blank" rel="noopener noreferrer">
              <strong>Documenting APIs</strong>
            </a>

            <span class="event">Software Crafters Barcelona, 2025</span>
          </li>

          <li class="talk">
            <a href="https://www.youtube.com/watch?v=HsPIX0tNlO8" target="_blank" rel="noopener noreferrer">
              <strong>AI in support teams</strong>
            </a>

            <span class="event">Software Crafters Barcelona, 2024</span>
          </li>

          <li class="talk">
            <strong>Enterprise knowledge management</strong>

            <span class="event">CAS (Agile Spain Conference), Madrid, 2024</span>
          </li>

          <li class="talk">
            <strong>We're capitalists</strong>

            <span class="event">Software Crafters Barcelona, 2023</span>
          </li>

          <li class="talk">
            <a href="https://www.youtube.com/watch?v=SYnLZCFtims" target="_blank" rel="noopener noreferrer">
              <strong>#NoMeetings: How to have fewer, more efficient meetings</strong>
            </a>

            <span class="event">CAS, Santiago de Compostela, 2022</span>
          </li>

          <li class="talk">
            <strong>Great interactions generate great products</strong>

            <span class="event">CAS, Vitoria, 2018 (workshop)</span>
          </li>

          <li class="talk">
            <a href="https://www.youtube.com/watch?v=1fs9DPdTKS8" target="_blank" rel="noopener noreferrer">
              <strong>DevOps: From the trenches to the boardroom</strong>
            </a>

            <span class="event">CAS, Alicante, 2016</span>
          </li>
        </ul>
  </div>
</Layout>

<style>
  .content-container {
    max-width: 1200px !important;
  }

  .content-container::after {
    content: "";
    display: table;
    clear: both;
  }

  .intro {
    margin-bottom: 2rem;
  }

  .talks-list-inline {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Photo carousel - always float right */
  .photo-carousel {
    float: right;
    width: 360px;
    height: 360px;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .photo-slide {
    position: absolute;
    opacity: 0;
    animation: fadeSlide 28s infinite;
    border-radius: 12px;
    overflow: hidden;
  }

  .photo-slide.portrait {
    width: 280px;
    height: 360px;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .photo-slide.landscape {
    width: 360px;
    height: 230px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .photo-slide:nth-child(1) { animation-delay: 0s; }
  .photo-slide:nth-child(2) { animation-delay: 4s; }
  .photo-slide:nth-child(3) { animation-delay: 8s; }
  .photo-slide:nth-child(4) { animation-delay: 12s; }
  .photo-slide:nth-child(5) { animation-delay: 16s; }
  .photo-slide:nth-child(6) { animation-delay: 20s; }
  .photo-slide:nth-child(7) { animation-delay: 24s; }

  .photo-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.4rem 0.6rem;
    font-size: 0.75rem;
    color: var(--color-gray-medium);
    background: rgba(255, 255, 255, 0.85);
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @keyframes fadeSlide {
    0%   { opacity: 0; }
    2%   { opacity: 1; }
    12%  { opacity: 1; }
    14%  { opacity: 0; }
    100% { opacity: 0; }
  }

  /* Mobile: smaller carousel, still floats right */
  @media (max-width: 768px) {
    .photo-carousel {
      width: 180px;
      height: 180px;
      margin-left: 1rem;
      margin-bottom: 1rem;
    }

    .photo-slide.portrait {
      width: 140px;
      height: 180px;
    }

    .photo-slide.landscape {
      width: 180px;
      height: 115px;
    }

    .talks-list-inline {
      clear: both; /* In mobile, talks go below carousel for full width */
    }
  }


  .talk {
    padding-left: 1.5rem;
    position: relative;
  }

  .talk::before {
    content: "–";
    position: absolute;
    left: 0;
    color: var(--color-gray-medium);
  }

  .talk strong {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .event {
    display: block;
    font-size: 0.9rem;
    color: var(--color-gray-medium);
    margin-top: 0.15rem;
  }

  @media (max-width: 768px) {
    .talk strong {
      font-size: 1rem;
    }
  }
</style>
