---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Speaking - Javi Rubio">
  <div class="content-container">
    <div class="speaking-header">
      <div class="speaking-intro">
        <h1>Speaking</h1>
        <p class="intro">I regularly speak at corporate events and tech conferences:</p>
      </div>
      <div class="photo-carousel" aria-hidden="true">
        <div class="photo-slide"></div>
        <div class="photo-slide"></div>
        <div class="photo-slide"></div>
        <div class="photo-slide"></div>
      </div>
    </div>

    <ul class="talks-list">
      <li class="talk">
        <a href="https://www.youtube.com/watch?v=IHIsuIlSiio" target="_blank" rel="noopener noreferrer">
          <strong>Documenting APIs</strong>
        </a>

        <span class="event">Software Crafters Barcelona, 2025</span>
      </li>

      <li class="talk">
        <a href="https://www.youtube.com/watch?v=HsPIX0tNlO8" target="_blank" rel="noopener noreferrer">
          <strong>AI in support teams</strong>
        </a>

        <span class="event">Software Crafters Barcelona, 2024</span>
      </li>

      <li class="talk">
        <strong>Enterprise knowledge management</strong>

        <span class="event">CAS (Agile Spain Conference), Madrid, 2024</span>
      </li>

      <li class="talk">
        <strong>We're capitalists</strong>

        <span class="event">Software Crafters Barcelona, 2023</span>
      </li>

      <li class="talk">
        <a href="https://www.youtube.com/watch?v=SYnLZCFtims" target="_blank" rel="noopener noreferrer">
          <strong>#NoMeetings: How to have fewer, more efficient meetings</strong>
        </a>

        <span class="event">CAS, Santiago de Compostela, 2022</span>
      </li>

      <li class="talk">
        <strong>Great interactions generate great products</strong>

        <span class="event">CAS, Vitoria, 2018 (workshop)</span>
      </li>

      <li class="talk">
        <a href="https://www.youtube.com/watch?v=1fs9DPdTKS8" target="_blank" rel="noopener noreferrer">
          <strong>DevOps: From the trenches to the boardroom</strong>
        </a>

        <span class="event">CAS, Alicante, 2016</span>
      </li>
    </ul>
  </div>
</Layout>

<style>
  .speaking-header {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .speaking-intro {
    flex: 1;
    min-width: 0;
  }

  .intro {
    margin-bottom: 0;
  }

  /* Photo carousel */
  .photo-carousel {
    flex-shrink: 0;
    width: 220px;
    height: 280px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .photo-slide {
    position: absolute;
    inset: 0;
    background-color: var(--color-gray-light);
    opacity: 0;
    animation: fadeSlide 16s infinite;
  }

  /* Placeholder colors — will be replaced by real photos */
  .photo-slide:nth-child(1) { background-color: #e0d5c9; animation-delay: 0s; }
  .photo-slide:nth-child(2) { background-color: #c9d5e0; animation-delay: 4s; }
  .photo-slide:nth-child(3) { background-color: #d5e0c9; animation-delay: 8s; }
  .photo-slide:nth-child(4) { background-color: #e0c9d5; animation-delay: 12s; }

  @keyframes fadeSlide {
    0%   { opacity: 0; }
    5%   { opacity: 1; }
    25%  { opacity: 1; }
    30%  { opacity: 0; }
    100% { opacity: 0; }
  }

  @media (max-width: 768px) {
    .speaking-header {
      gap: 1rem;
    }

    .photo-carousel {
      width: 130px;
      height: 170px;
      border-radius: 8px;
    }
  }

  .talks-list {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .talk {
    padding-left: 1.5rem;
    position: relative;
  }

  .talk::before {
    content: "–";
    position: absolute;
    left: 0;
    color: var(--color-gray-medium);
  }

  .talk strong {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .event {
    display: block;
    font-size: 0.9rem;
    color: var(--color-gray-medium);
    margin-top: 0.15rem;
  }

  @media (max-width: 768px) {
    .talk strong {
      font-size: 1rem;
    }
  }
</style>
