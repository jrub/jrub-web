---
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">Javier Rubio</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/speaking">Speaking</a>
          <a href="/contact">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-links">
        <a href="https://github.com/jrub" target="_blank" rel="noopener noreferrer">GitHub</a>
        <span>|</span>
        <a href="https://linkedin.com/in/javi-rubio" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <span>|</span>
        <a href="https://nomeetings.work" target="_blank" rel="noopener noreferrer">#NoMeetings</a>
      </div>
    </footer>
  </body>
</html>

<style>
  @import '../styles/global.css';

  header {
    padding: 2rem;
    border-bottom: 1px solid var(--color-gray-light);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--color-black);
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-magenta);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a:hover {
    color: var(--color-magenta);
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    min-height: calc(100vh - 200px);
  }

  footer {
    padding: 2rem;
    border-top: 1px solid var(--color-gray-light);
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .footer-links span {
    color: var(--color-gray-medium);
  }
</style>
