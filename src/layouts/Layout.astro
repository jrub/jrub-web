---
import '../styles/global.css';
const { title } = Astro.props;
const description = "Helping teams build better products, knowledge systems, and sustainable work cultures. 20 years at the intersection of product, engineering, and knowledge management.";
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/profile.jpg', Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/profile.jpg', Astro.url)} />

    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">Javi Rubio</a>
        <div class="nav-links">
          <a href="/speaking" class:list={[{ active: currentPath === '/speaking' || currentPath === '/speaking/' }]}>Speaking</a>
          <a href="/contact" class:list={[{ active: currentPath === '/contact' || currentPath === '/contact/' }]}>Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-links">
        <a href="https://github.com/jrub" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <span>|</span>
        <a href="https://linkedin.com/in/javi-rubio" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <span>|</span>
        <a href="https://bsky.app/profile/jrubr.bsky.social" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.63 3.32 3.545 5.738 3.303-3.5.645-6.924 2.008-4.843 6.508 2.269 4.404 5.021 3.023 6.364 2.23C9.14 21.507 11.2 18.792 12 16.998c.8 1.794 2.86 4.509 4.117 5.29 1.343.793 4.095 2.174 6.364-2.23 2.081-4.5-1.343-5.863-4.843-6.508 2.418.242 4.953-.674 5.738-3.303C23.622 9.418 24 4.458 24 3.768c0-.69-.139-1.861-.902-2.203-.659-.3-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>
          </svg>
          Bluesky
        </a>
        <span>|</span>
        <a href="https://nomeetings.work" target="_blank" rel="noopener noreferrer">#NoMeetings</a>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    position: sticky;
    top: 0;
    background-color: var(--color-white);
    padding: 1rem 2rem;
    border-bottom: 1px solid var(--color-gray-light);
    z-index: 100;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--color-black);
  }

  .logo:hover {
    text-decoration: none;
    color: var(--color-magenta);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a:hover {
    color: var(--color-magenta);
  }

  .nav-links a.active {
    color: var(--color-magenta);
    font-weight: 600;
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
    min-height: calc(100vh - 200px);
  }

  footer {
    padding: 2rem;
    border-top: 1px solid var(--color-gray-light);
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-links svg {
    vertical-align: middle;
  }

  .footer-links span {
    color: var(--color-gray-medium);
  }

  @media (max-width: 768px) {
    header {
      padding: 0.75rem 1rem;
    }

    .nav-links {
      gap: 1rem;
    }

    main {
      padding: 2rem 1rem 1rem;
    }

    footer {
      padding: 0.75rem 1rem;
    }

    .footer-links {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .footer-links span {
      display: none;
    }
  }
</style>
